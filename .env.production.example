# Production Frontend Environment
# Set these in your deployment platform (Vercel, Netlify, etc.)

# API Configuration (IMPORTANT: Update for production)
VITE_API_URL=https://your-api-domain.com/api
VITE_API_TIMEOUT=15000

# Application Configuration
VITE_APP_NAME="Skill Swap & Thrive"  
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=production

# Authentication
VITE_JWT_EXPIRY=24h

# File Upload
VITE_MAX_FILE_SIZE=5242880
VITE_ALLOWED_FILE_TYPES="image/jpeg,image/png,image/gif,image/webp"

# Feature Flags
VITE_ENABLE_ADMIN=true
VITE_ENABLE_MESSAGING=true
VITE_ENABLE_SCHEDULING=true

# Production Services (CONFIGURE THESE)
VITE_ANALYTICS_ID=your_production_analytics_id
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Social Login (Optional)  
VITE_GOOGLE_CLIENT_ID=your_production_google_client_id
VITE_GITHUB_CLIENT_ID=your_production_github_client_id